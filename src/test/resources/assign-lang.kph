@version 1;

language AssignLang;

tokens {
    @skip 'WS' <- "[ \t\r\n]+";
    'ID'     <- "[a-zA-Z_][a-zA-Z0-9_]*";
    'NUM'    <- "[0-9]+";
    'ASSIGN' <- ":=";
    'SEMI'   <- ";";
    'COMMA'  <- ",";
}

rules {
    [prog] Prog => Stmt+;
    [assign] Stmt => 'ID' 'ASSIGN' Expr 'SEMI';
    [list] Expr => 'NUM' ('COMMA' 'NUM')*;
}
