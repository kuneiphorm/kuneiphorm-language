@version 1;

language ExprLang;

tokens {
    @skip 'WS' <- "[ \t\r\n]+";
    'NUM'  <- "[0-9]+";
    'ID'   <- "[a-zA-Z_][a-zA-Z0-9_]*";
    'PLUS' <- "\+";
    'STAR' <- "\*";
    'LP'   <- "\(";
    'RP'   <- "\)";
}

rules {
    [add] Expr => Expr 'PLUS' Term;
    [term] Expr => Term;
    [mul] Term => Term 'STAR' Factor;
    [factor] Term => Factor;
    [group] Factor => 'LP' Expr 'RP';
    [num] Factor => 'NUM';
    [id] Factor => 'ID';
}
